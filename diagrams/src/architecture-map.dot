// Resolve platform — end-to-end flow. Structural only; layout is computed.
// The top row is ANY consumer of the API, not a single privileged path.
digraph architecture_map {
  rankdir=TB;
  node [shape=box, fontsize=14, margin="0.3,0.18", fontname="Helvetica"];

  // consumers — any caller of the platform's HTTP API
  spa     [class="consumer", label="SPA (browser)"];
  agent   [class="consumer", label="agent / script"];
  cli     [class="consumer", label="CLI"];
  bridge  [class="consumer", label="CI bridge\n(e.g. GitHub)"];

  platform     [class="platform", label="amplifier-resolve\nFastAPI platform daemon"];
  dotgraph     [class="resolver", label="resolver: dot-graph"];
  orchestrator [class="resolver", label="resolver: orchestrator"];
  understudy   [class="resolver", label="resolver: understudy"];
  viewports    [class="viewport", label="resolver viewports\n(viewport.js)"];
  provisioning [class="provision", label="amplifier-bundle-resolve\nprovisioning / DTU"];

  spa    -> platform [label="POST /instances"];
  agent  -> platform [label="POST /instances"];
  cli    -> platform;
  bridge -> platform;

  platform -> dotgraph     [label="launch container"];
  platform -> orchestrator;
  platform -> understudy;

  dotgraph     -> viewports [label="events / state"];
  orchestrator -> viewports;
  understudy   -> viewports;

  viewports    -> spa       [label="loaded by"];
  provisioning -> platform  [label="stands up", style=dashed];
}
