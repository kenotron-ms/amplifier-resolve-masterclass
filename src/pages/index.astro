---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getOrderedChapters, chapterLabel } from '../utils/chapters';

const chapters = await getOrderedChapters();
const base = import.meta.env.BASE_URL;
const href = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
const chUrl = (id: string) => href(`chapters/${id}`);

const numOf = (ch: any) => (typeof ch.data.chapter === 'number' ? ch.data.chapter : 99);
const isApp = (ch: any) => ch.id.startsWith('appendix');

const arcDefs = [
  { id: 'I',   title: 'The Mental Model',      blurb: 'why Resolve is shaped the way it is',        match: (n: number) => n >= 1 && n <= 3 },
  { id: 'II',  title: 'The Machine',           blurb: 'the platform mechanism, part by part',       match: (n: number) => n >= 4 && n <= 9 },
  { id: 'III', title: 'Strategies & Surfaces', blurb: 'the resolvers, their faces, the dev loop',   match: (n: number) => n >= 10 && n <= 12 },
  { id: 'IV',  title: 'The Whole',             blurb: 'assemble it, keep it, extend it',            match: (n: number, app: boolean) => n === 13 || app },
];
const arcs = arcDefs.map((a) => ({ ...a, items: chapters.filter((ch) => a.match(numOf(ch), isApp(ch))) }));

const gloss: Record<string, string> = {
  '01-introduction': 'what Resolve is, and the unit of work',
  '02-architecture-map': 'the whole stack, and how work arrives',
  '03-design-philosophy': 'the bright line, and why it holds',
  '04-instance-lifecycle': 'eight statuses, four phases',
  '05-resolver-protocol': 'the twelve-member contract',
  '06-isolation-and-containers': 'the sealed box and its bus',
  '07-event-vocabulary': 'the observability contract',
  '08-a2ui-and-interaction': 'the three ways to address a run',
  '09-session-engine-sdk': 'the SDK beneath every resolver',
  '10-three-resolvers': 'three theories of correctness',
  '11-viewports-and-spa': "a resolver's own face",
  '12-provisioning-and-inner-loop': 'the inner development loop',
  '13-complete-picture': "six layers, and what is next",
  'appendix-glossary-and-invariants': 'the glossary and the invariants',
};

const audience: [string, string][] = [
  ['The new owner', 'You have inherited the platform. Begin here; leave fluent in every part of it.'],
  ['The resolver author', 'Write a new strategy the platform will run without changing a line.'],
  ['The contributor', 'Extend the daemon, the SDK, or a viewport without crossing the bright line.'],
  ['The integrator', 'Drive Resolve from your own application, agent, pipeline, or shell — it is an interface, not an application.'],
  ['The architect', 'Study a working, consumer-agnostic platform for autonomous work, entire.'],
];

const carry: string[] = [
  'name the bright line, and use it to place any new code;',
  'trace an instance through its eight statuses and four phases;',
  'implement the twelve-member resolver protocol;',
  'emit the event vocabulary, and honor its completion invariant;',
  'reason about isolation, and the bus that coordinates it;',
  "address a run through A2UI's three surfaces and the data bus;",
  'wield the SDK — prepared sessions, disposable dispatch, adversarial review, deterministic gates;',
  'weigh the three resolvers, and choose between them;',
  'ship a viewport the shell need never understand;',
  'run the inner loop, and respect the gate that guards it.',
];

const exam: [string, string, string][] = [
  ['03-design-philosophy', '3', 'State the bright line in one sentence — and name one policy that must never live in the platform.'],
  ['04-instance-lifecycle', '4', 'Recite the eight statuses. What moves an instance into awaiting_input, and what resumes it?'],
  ['05-resolver-protocol', '5', 'Name the twelve protocol members. What three things does run() receive?'],
  ['07-event-vocabulary', '7', 'Why must resolver:completed be emitted at every exit path — and what follows if one path omits it?'],
  ['07-event-vocabulary', '7', 'merge_state or update_state: which does the daemon call for partial updates, and why?'],
  ['08-a2ui-and-interaction', '8', 'Name the three interaction surfaces, and who opens each.'],
  ['09-session-engine-sdk', '9', 'What is the adversarial reviewer shown, and why bound it to the diff?'],
  ['10-three-resolvers', '10', 'Distinguish dot-graph, orchestrator, and understudy by their theory of correctness.'],
  ['11-viewports-and-spa', '11', 'Explain the dual-React problem, and why React is externalized.'],
  ['12-provisioning-and-inner-loop', '12', 'Why is the Gitea sidecar reached at DTU_INCUS_IP, not HOST_GW?'],
];
---

<BaseLayout title="Amplifier Resolve — Masterclass">
  <section class="frontis">
    <p class="overline">Amplifier · Masterclass</p>
    <h1>Amplifier Resolve</h1>
    <p class="frontis-sub">An operating system for autonomous work</p>

    <p class="preface">
      A request arrives — <em>resolve this</em>. Resolve seals it inside a container and runs a
      pluggable <strong>resolver</strong> to completion: narrating every step through a fixed
      contract, relaying a person in and out, returning an artifact. One platform; many strategies;
      complete isolation. What follows is the whole of it — from first principles, through the
      running code, to where the platform is going.
    </p>

    <blockquote class="epigraph">
      <p>The platform provides mechanism. The resolver provides policy.</p>
      <cite>Hold that one line, and the rest follows.</cite>
    </blockquote>
  </section>

  <hr class="fleuron" aria-hidden="true" />

  <section class="leaf">
    <p class="leaf-label"><span class="rn">I</span> Who this is for</p>
    <dl class="register">
      {audience.map(([role, line]) => (
        <div class="reg-row">
          <dt>{role}</dt>
          <dd>{line}</dd>
        </div>
      ))}
    </dl>
    <p class="aside">
      Assumed: a working knowledge of Python, HTTP, and containers. The
      <a href="https://anderlpz.github.io/amplifier-masterclass/" rel="noopener"> Amplifier Core masterclass</a>
      is a companion, not a prerequisite — Resolve lifts its mechanism-versus-policy idea one layer up.
    </p>
  </section>

  <section class="leaf">
    <p class="leaf-label"><span class="rn">II</span> What you carry away</p>
    <p class="leaf-lead">By the close, you will be able to —</p>
    <ul class="carry">
      {carry.map((c) => <li>{c}</li>)}
    </ul>
  </section>

  <section class="leaf">
    <p class="leaf-label"><span class="rn">III</span> The path</p>
    <p class="leaf-lead">
      Thirteen chapters and an appendix, in four parts. Read them in order, the first time; the
      parts are built to rest upon one another.
    </p>
    <div class="contents">
      {arcs.map((arc) => (
        <div class="part">
          <p class="part-title">Part {arc.id} <span class="part-blurb">— {arc.blurb}</span></p>
          <ol class="entries">
            {arc.items.map((ch) => (
              <li>
                <a class="entry" href={chUrl(ch.id)}>
                  <span class="e-num">{chapterLabel(ch) === 'Appendix' ? 'A' : chapterLabel(ch)}</span>
                  <span class="e-title">{ch.data.title}</span>
                  <span class="e-dots" aria-hidden="true"></span>
                  <span class="e-gloss">{gloss[ch.id]}</span>
                </a>
              </li>
            ))}
          </ol>
        </div>
      ))}
    </div>
  </section>

  <section class="leaf">
    <p class="leaf-label"><span class="rn">IV</span> How to read it</p>
    <dl class="register">
      <div class="reg-row"><dt>Go in order</dt><dd>the first time. Chapters 1–3 set the mental model; do not skip them.</dd></div>
      <div class="reg-row"><dt>Mind the Design Decisions</dt><dd>each a single choice, with <em>why the alternative is worse</em>. If you keep nothing else, keep these.</dd></div>
      <div class="reg-row"><dt>Follow the §</dt><dd>cross-references lead to where an idea is paid off in full.</dd></div>
      <div class="reg-row"><dt>Allow an unhurried hour</dt><dd>for a first pass. It is written to reward a second.</dd></div>
    </dl>
  </section>

  <section class="leaf">
    <p class="leaf-label"><span class="rn">V</span> Returning to it</p>
    <dl class="register">
      <div class="reg-row"><dt>Keep the Appendix at hand</dt><dd>the glossary and the cross-repo invariants are the daily reference.</dd></div>
      <div class="reg-row"><dt>Enter by subsystem</dt><dd>the SDK sends you to §9; the event loop to §7; the viewports to §11.</dd></div>
      <div class="reg-row"><dt>Before you change the platform</dt><dd>re-read §3 and §13, and ask of your change: mechanism, or policy?</dd></div>
    </dl>
  </section>

  <hr class="fleuron" aria-hidden="true" />

  <section class="leaf">
    <p class="leaf-label">The examination</p>
    <p class="leaf-lead">
      You have arrived when you can answer these from memory. Each marks where its answer lives;
      attempt it first, then go and check.
    </p>
    <ol class="exam">
      {exam.map(([id, sec, q]) => (
        <li><span class="q">{q}</span> <a class="q-ref" href={chUrl(id)}>§{sec}</a></li>
      ))}
    </ol>
  </section>

  <p class="coda">Read it once to understand the platform. Return to it to master it.</p>

  <details class="full-toc">
    <summary>Full table of contents</summary>
    <ol class="toc-grid">
      {chapters.map((ch) => {
        const lbl = chapterLabel(ch);
        return (
          <li>
            <a href={chUrl(ch.id)}>
              <span class="num">{lbl === 'Appendix' ? 'A' : lbl}</span>
              <span class="title">{ch.data.title}</span>
            </a>
          </li>
        );
      })}
    </ol>
  </details>
</BaseLayout>
